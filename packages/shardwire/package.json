{
	"name": "shardwire",
	"version": "1.5.1",
	"description": "Discord-first bridge between a bot process and external apps over WebSocket.",
	"homepage": "https://unloopedmido.github.io/shardwire/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/unloopedmido/shardwire.git"
	},
	"bugs": {
		"url": "https://github.com/unloopedmido/shardwire/issues",
		"email": "cored.developments@gmail.com"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"scripts": {
		"clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
		"build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
		"typecheck": "tsc --noEmit",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"verify": "npm run lint && npm run format:check && npm run test:coverage && npm run typecheck && npm run build",
		"prepublishOnly": "npm run verify"
	},
	"keywords": [
		"discord",
		"discord-bot",
		"websocket",
		"bot-bridge",
		"realtime",
		"typescript",
		"discord-events",
		"discord-apps",
		"discord-api"
	],
	"author": "Mohammed Haism <cored.developments@gmail.com>",
	"license": "MIT",
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18.18"
	},
	"dependencies": {
		"discord-api-types": "^0.38.34",
		"discord.js": "^14.26.2",
		"ws": "^8.20.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^25.6.0",
		"@types/ws": "^8.18.1",
		"@vitest/coverage-v8": "^4.1.4",
		"eslint": "^10.2.0",
		"globals": "^17.5.0",
		"prettier": "^3.5.3",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vitest": "^4.1.4"
	},
	"publishConfig": {
		"access": "public"
	}
}
