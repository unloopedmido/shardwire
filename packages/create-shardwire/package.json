{
	"name": "create-shardwire",
	"version": "1.0.8",
	"description": "Interactive scaffold for Shardwire Discord bot + app projects.",
	"type": "module",
	"bin": {
		"create-shardwire": "./dist/cli.js"
	},
	"files": [
		"dist",
		"templates"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"lint": "eslint . --max-warnings=0",
		"format:check": "prettier --check .",
		"format": "prettier --write .",
		"test": "vitest run",
		"verify": "npm run lint && npm run format:check && npm run test && npm run typecheck && npm run build",
		"prepublishOnly": "npm run build"
	},
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"picocolors": "^1.1.1",
		"validate-npm-package-name": "^7.0.2"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.6.0",
		"eslint": "^10.2.1",
		"globals": "^17.5.0",
		"prettier": "^3.8.3",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.58.2",
		"vitest": "^4.1.4"
	},
	"keywords": [
		"shardwire",
		"discord",
		"create",
		"scaffold",
		"cli"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/unloopedmido/shardwire.git",
		"directory": "packages/create-shardwire"
	}
}
