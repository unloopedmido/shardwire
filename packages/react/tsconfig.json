{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"declaration": true,
		"jsx": "react-jsx",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"ignoreDeprecations": "6.0",
		"rootDir": "src",
		"outDir": "dist",
		"lib": ["ES2022", "DOM"]
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
