{
	"name": "@shardwire/react",
	"version": "0.1.0",
	"description": "Optional React hooks for Shardwire app bridges (dashboards and controllers).",
	"homepage": "https://shardwire.js.org/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/unloopedmido/shardwire.git",
		"directory": "packages/react"
	},
	"license": "MIT",
	"keywords": ["discord", "react", "shardwire", "websocket"],
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": ["dist"],
	"engines": {
		"node": ">=18.18"
	},
	"scripts": {
		"clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
		"build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --external react --external shardwire",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"shardwire": ">=1.8.0"
	},
	"devDependencies": {
		"@types/react": "^19.2.7",
		"react": "^19.2.3",
		"shardwire": "*",
		"tsup": "^8.5.1",
		"typescript": "^6.0.2"
	}
}
