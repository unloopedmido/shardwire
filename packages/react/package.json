{
	"name": "@shardwire/react",
	"version": "0.5.0",
	"description": "Optional React hooks for Shardwire app bridges (dashboards and controllers).",
	"homepage": "https://shardwire.js.org/",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/unloopedmido/shardwire.git",
		"directory": "packages/react"
	},
	"license": "MIT",
	"keywords": [
		"discord",
		"react",
		"shardwire",
		"websocket"
	],
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
		"build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --external react --external shardwire",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"shardwire": "^2.1.0"
	},
	"peerDependencies": {
		"react": ">=18.0.0"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.14",
		"jsdom": "^29.0.2",
		"react": "^19.2.5",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.4"
	}
}
