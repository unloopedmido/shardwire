			"resolved": "packages/bot",
			"link": true
		},
		"node_modules/dotenv": {
			"version": "16.6.1",
			"resolved": "https://registry.npmjs.org/dotenv/-/dotenv-16.6.1.tgz",
			"integrity": "sha512-uBq4egWHTcTt33a72vpSG0z3HnPuIl6NqYcTrKEg2azoEyl2hpW0zqlxysq2pK9HlDIHyHyakeYaYnSAwd8bow==",
			"license": "BSD-2-Clause",
			"engines": {
				"node": ">=12"
			},
			"funding": {
				"url": "https://dotenvx.com"
			}
		},
		"node_modules/shardwire": {
			"resolved": "../../packages/shardwire",
			"link": true
		},
		"packages/app": {
			"name": "@example/shardwire-workspace-app",
			"dependencies": {
				"dotenv": "^16.4.7",
				"shardwire": "file:../../../../packages/shardwire"
			}
		},
		"packages/bot": {
			"name": "@example/shardwire-workspace-bot",
			"dependencies": {
				"dotenv": "^16.4.7",
				"shardwire": "file:../../../../packages/shardwire"
			}
		}
	}
