{
	"name": "shardwire-workspace-example",
	"lockfileVersion": 3,
	"requires": true,
	"packages": {
		"": {
			"name": "shardwire-workspace-example",
			"workspaces": [
				"packages/bot",
				"packages/app"
			],
			"engines": {
				"node": ">=22.0.0"
			}
		},
		"../../packages/shardwire": {
			"version": "2.0.1",
			"license": "MIT",
			"dependencies": {
				"discord-api-types": "^0.38.46",
				"discord.js": "^14.26.3",
				"ws": "^8.20.0"
			},
			"devDependencies": {
				"@eslint/js": "^10.0.1",
				"@types/node": "^25.6.0",
				"@types/ws": "^8.18.1",
				"@vitest/coverage-v8": "^4.1.4",
				"eslint": "^10.2.0",
				"globals": "^17.5.0",
				"prettier": "^3.8.3",
				"tsup": "^8.5.1",
				"tsx": "^4.21.0",
				"typescript": "^6.0.2",
				"typescript-eslint": "^8.58.2",
				"vitest": "^4.1.4"
			},
			"engines": {
				"node": ">=22.0.0"
			}
		},
		"node_modules/@example/shardwire-workspace-app": {
			"resolved": "packages/app",
